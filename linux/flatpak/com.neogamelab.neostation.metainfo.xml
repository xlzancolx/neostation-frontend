<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.neogamelab.neostation</id>

  <name>NeoStation</name>
  <summary>Modern, multi-platform emulation frontend</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0</project_license>

  <description>
    <p>
      NeoStation provides a fast, lightweight, and customizable experience for
      managing and launching retro games across desktop devices, with seamless
      integration for RetroArch and standalone emulators.
    </p>
    <ul>
      <li>Modern and customizable UI with themes and animations</li>
      <li>ROM and platform collection management</li>
      <li>RetroArch and standalone emulator auto-detection and configuration</li>
      <li>RetroAchievements support (achievements, leaderboards, game hashes)</li>
      <li>ScreenScraper integration (metadata and media scraping)</li>
      <li>Cloud save sync via NeoSync</li>
      <li>Full gamepad and keyboard navigation</li>
      <li>Available in 10 languages</li>
    </ul>
  </description>

  <url type="homepage">https://github.com/miguelsotobaez/neostation-frontend</url>
  <url type="bugtracker">https://github.com/miguelsotobaez/neostation-frontend/issues</url>
  <url type="donation">https://github.com/sponsors/miguelsotobaez</url>
  <url type="vcs-browser">https://github.com/miguelsotobaez/neostation-frontend</url>

  <launchable type="desktop-id">com.neogamelab.neostation.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>NeoStation main interface</caption>
      <image type="source">https://raw.githubusercontent.com/miguelsotobaez/neostation-frontend/main/assets/images/logo.png</image>
    </screenshot>
  </screenshots>

  <developer id="com.neogamelab">
    <name>NeoGameLab</name>
  </developer>

  <categories>
    <category>Game</category>
    <category>Emulator</category>
  </categories>

  <keywords>
    <keyword>emulation</keyword>
    <keyword>retro</keyword>
    <keyword>gaming</keyword>
    <keyword>rom</keyword>
    <keyword>retroarch</keyword>
    <keyword>emulator</keyword>
    <keyword>launcher</keyword>
  </keywords>

  <releases>
    <release version="0.9.0" date="2026-05-29">
      <description>
        <p>Beta release with full feature set.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />

  <requires>
    <display_length compare="ge">small</display_length>
    <memory compare="ge">512M</memory>
    <internet>offline-only</internet>
  </requires>

  <provides>
    <binary>neostation</binary>
  </provides>

  <custom>
    <value key="flathub::manifest">https://raw.githubusercontent.com/miguelsotobaez/neostation-frontend/main/linux/flatpak/com.neogamelab.neostation.yml</value>
  </custom>
</component>
